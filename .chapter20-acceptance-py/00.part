require(not (CONTROL / '41-chapter-20-acceptance-review.md').exists(), 'Chapter 20 review already exists')
require(git_blob(draft) == EXPECTED_DRAFT, f'draft blob changed: {git_blob(draft)}')
require(len(draft.read_text(encoding='utf-8').split()) == 4171, 'draft word count changed')
require(git_blob(mission) == EXPECTED_MISSION, f'mission-lock blob changed: {git_blob(mission)}')
require(not list(BOOK.rglob('chapter-21.md')), 'Chapter 21 prose exists')
require(not list(CONTROL.glob('*chapter-21-mission-lock*.md')), 'Chapter 21 mission lock exists')

prose = draft.read_text(encoding='utf-8')

# Repair 1: re-stage the consequential custody decision after the carrier/authorizer reversal.
