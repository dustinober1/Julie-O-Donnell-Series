from pathlib import Path
import hashlib
import re
import subprocess
import textwrap

ROOT = Path('.')
BOOK = ROOT / 'books/book-01'
CONTROL = BOOK / 'control'
CHAPTERS = BOOK / 'manuscript/chapters'
DRAFTS = BOOK / 'drafts'
EXPECTED_BASE = '4616d77066fc82c3bbb6f6462a413a657976b1d8'
EXPECTED_DRAFT = 'd983f952caca56c41b9f7d1ef976a9ae1b281a78'
EXPECTED_MISSION = 'c074e4f6f9ec9cddcbc701e2923f34b3082ede5a'
STARTING_ACCEPTED = 103369

def run(*args):
    return subprocess.check_output(args, text=True).strip()

def git_blob(path):
    return run('git', 'hash-object', str(path))

def require(condition, message):
    if not condition:
        raise SystemExit(message)

def write(path, content):
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content.rstrip() + '\n', encoding='utf-8')

def replace_once(text, old, new, label):
    count = text.count(old)
    require(count == 1, f'{label}: expected one match, found {count}')
    return text.replace(old, new, 1)

def upsert_marker(path, tag, title, body):
    text = path.read_text(encoding='utf-8')
    block = f'<!-- {tag}_START -->\n## {title}\n\n{body.rstrip()}\n<!-- {tag}_END -->'
    pattern = re.compile(rf'<!-- {re.escape(tag)}_START -->.*?<!-- {re.escape(tag)}_END -->', re.S)
    if pattern.search(text):
        text = pattern.sub(block, text, count=1)
    else:
        first_nl = text.find('\n')
        require(first_nl >= 0 and text.startswith('# '), f'{path}: missing top heading')
        text = text[:first_nl+1] + '\n' + block + '\n' + text[first_nl+1:].lstrip('\n')
    write(path, text)

merge_base = run('git', 'merge-base', 'HEAD', 'origin/main')
require(merge_base == EXPECTED_BASE, f'baseline drift: {merge_base}')

draft = DRAFTS / 'chapter-20.md'
mission = CONTROL / '40-chapter-20-mission-lock.md'
require(draft.is_file(), 'Chapter 20 draft missing')
